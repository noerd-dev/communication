{
    "name": "noerd/communication",
    "description": "Communication module for noerd platform — central email sending and communications log",
    "type": "library",
    "version": "v0.1.3",
    "license": "proprietary",
    "require": {
        "noerd/noerd": "^0.6",
        "noerd/customer": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "Noerd\\Communication\\": "src/",
            "Noerd\\Communication\\Tests\\": "tests/",
            "Noerd\\Communication\\Database\\Factories\\": "database/factories/",
            "Noerd\\Communication\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
